# ============================================================
# Staffly AI - Environment Variables
# Copy to .env and fill with actual values
# ============================================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# JWT Secret (generate a long random string)
VITE_JWT_SECRET=your-very-long-and-secure-secret-key-change-this-in-production

# Application
VITE_APP_NAME=Staffly AI
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=/api

# Email Configuration (Optional)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=noreply@stafflyai.com

# File Upload
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png
